{
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/blog/:slug", "has": [{ "type": "query", "key": "spa" }], "destination": "/index.html" },
    { "source": "/blog/:slug", "destination": "/api/blog-preview?slug=:slug" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
